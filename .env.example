# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
# Tell the client to regenerate the Odds API key after deployment.

# ── External APIs ─────────────────────────────────────────────────────────────
ODDS_API_KEY=
OPENWEATHER_API_KEY=

# ── Infrastructure ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sharpline:sharpline_dev@localhost:5432/sharpline
REDIS_URL=redis://localhost:6379/0

# ── App ──────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme
# auto | rich | lean
# rich  = paid plan, poll every 30s near kickoff
# lean  = free/starter plan, poll only imminent games
# auto  = read credits remaining and decide at runtime
ODDS_POLL_MODE=auto
CORS_ORIGINS=http://localhost:5173
